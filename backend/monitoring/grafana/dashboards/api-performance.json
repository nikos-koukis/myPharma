      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "histogram_quantile(0.95, sum(rate(mypharma_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "P95",
          "instant": true,
          "range": false
