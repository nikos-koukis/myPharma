    {
      "id": 6,
      "title": "Issues Breakdown",
      "type": "piechart",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 5 },
      "datasource": { "type": "postgres", "uid": "postgresql" },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "reduceOptions": { "values": true, "calcs": ["lastNotNull"], "fields": "" },
        "legend": { "displayMode": "list", "placement": "right" },
        "pieType": "pie",
        "tooltip": { "mode": "single" }
      },
      "targets": [{
        "datasource": { "type": "postgres", "uid": "postgresql" },
        "rawSql": "SELECT COALESCE(issue, 'Valid') AS \"Issue\", COUNT(*) AS \"Count\"\nFROM geo_validations\nGROUP BY issue\nORDER BY COUNT(*) DESC",
        "format": "table",
        "rawQuery": true,
        "refId": "A"
      }]
    },
    {
      "id": 7,
      "title": "Invalid by Region",
      "type": "bargauge",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 5 },
      "datasource": { "type": "postgres", "uid": "postgresql" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 5 },
            { "color": "red", "value": 10 }
          ]}
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "values": true, "calcs": ["lastNotNull"], "fields": "" },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true
      },
      "targets": [{
        "datasource": { "type": "postgres", "uid": "postgresql" },
        "rawSql": "SELECT region AS \"Region\", COUNT(*) AS \"Invalid\"\nFROM geo_validations\nWHERE is_valid = false\nGROUP BY region\nORDER BY COUNT(*) DESC\nLIMIT 10",
        "format": "table",
        "rawQuery": true,
        "refId": "A"
      }]
