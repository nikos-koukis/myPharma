      "targets": [{
        "datasource": { "type": "postgres", "uid": "postgresql" },
        "rawSql": "SELECT ROUND(100.0 * SUM(CASE WHEN is_valid THEN 1 ELSE 0 END) / NULLIF(COUNT(*), 0), 1) AS \"Rate\" FROM geo_validations",
        "format": "table",
