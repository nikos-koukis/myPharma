      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "irate(redis_keyspace_hits_total[5m]) / (irate(redis_keyspace_hits_total[5m]) + irate(redis_keyspace_misses_total[5m])) * 100",
          "legendFormat": "Cache Hit Rate",
          "instant": true,
          "range": false,
          "editorMode": "code"
        }
      ]
    },
