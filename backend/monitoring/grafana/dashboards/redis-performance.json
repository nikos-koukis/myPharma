      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "red", "value": 0 },
              { "color": "yellow", "value": 80 },
              { "color": "green", "value": 90 }
            ]
          },
          "mappings": [],
          "unit": "percent",
          "decimals": 2,
          "min": 0,
          "max": 100
