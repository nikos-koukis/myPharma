            "uid": "postgresql"
          },
          "rawSql": "WITH today AS (\n  SELECT scr.city, scr.pharmacies_found\n  FROM scrape_city_results scr\n  JOIN scrape_runs sr ON sr.id = scr.scrape_run_id\n  WHERE sr.started_at::date = CURRENT_DATE AND scr.status = 'success'\n),\nyesterday AS (\n  SELECT scr.city, scr.pharmacies_found\n  FROM scrape_city_results scr\n  JOIN scrape_runs sr ON sr.id = scr.scrape_run_id\n  WHERE sr.started_at::date = CURRENT_DATE - 1 AND scr.status = 'success'\n)\nSELECT t.city AS \"City\",\n       y.pharmacies_found AS \"Yesterday\",\n       t.pharmacies_found AS \"Today\",\n       ROUND((1.0 - t.pharmacies_found::numeric / NULLIF(y.pharmacies_found, 0)) * 100, 1) AS \"Drop %\"\nFROM today t\nJOIN yesterday y ON t.city = y.city\nWHERE y.pharmacies_found > 0\n  AND t.pharmacies_found < y.pharmacies_found * 0.7\nORDER BY \"Drop %\" DESC",
          "format": "table",
          "rawQuery": true,
          "refId": "A"
        }
      ]
    },
