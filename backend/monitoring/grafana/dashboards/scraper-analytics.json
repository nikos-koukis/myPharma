    {
      "id": 9,
      "title": "Today vs Yesterday: Pharmacies Per City",
      "type": "barchart",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 15 },
      "datasource": {
        "type": "postgres",
        "uid": "postgresql"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "fillOpacity": 80,
            "gradientMode": "none",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "lineWidth": 1,
            "scaleDistribution": { "type": "linear" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Today" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Yesterday" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Difference" },
            "properties": [
              { "id": "custom.hideFrom", "value": { "legend": false, "tooltip": false, "viz": true } }
            ]
          }
        ]
      },
      "options": {
        "barRadius": 0.1,
        "barWidth": 0.8,
        "fullHighlight": false,
        "groupWidth": 0.7,
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true },
        "orientation": "vertical",
        "showValue": "auto",
        "stacking": "none",
        "tooltip": { "mode": "multi", "sort": "none" },
        "xField": "city",
        "xTickLabelRotation": -45,
        "xTickLabelSpacing": 0
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "postgresql"
          },
          "rawSql": "WITH today AS (\n  SELECT scr.city, scr.pharmacies_found, scr.prefecture\n  FROM scrape_city_results scr\n  JOIN scrape_runs sr ON sr.id = scr.scrape_run_id\n  WHERE sr.started_at::date = CURRENT_DATE\n    AND scr.status = 'success'\n    AND scr.prefecture LIKE '${prefecture:raw}'\n    AND scr.city LIKE '${city:raw}'\n),\nyesterday AS (\n  SELECT scr.city, scr.pharmacies_found, scr.prefecture\n  FROM scrape_city_results scr\n  JOIN scrape_runs sr ON sr.id = scr.scrape_run_id\n  WHERE sr.started_at::date = CURRENT_DATE - 1\n    AND scr.status = 'success'\n    AND scr.prefecture LIKE '${prefecture:raw}'\n    AND scr.city LIKE '${city:raw}'\n)\nSELECT COALESCE(t.city, y.city) AS city,\n       COALESCE(t.pharmacies_found, 0) AS \"Today\",\n       COALESCE(y.pharmacies_found, 0) AS \"Yesterday\",\n       COALESCE(t.pharmacies_found, 0) - COALESCE(y.pharmacies_found, 0) AS \"Difference\"\nFROM today t\nFULL OUTER JOIN yesterday y ON t.city = y.city\nORDER BY \"Difference\" ASC",
          "format": "table",
          "rawQuery": true,
          "refId": "A"
        }
      ]
    },
