    {
      "id": 10,
      "title": "Cities Missing Today",
      "description": "Cities that were scraped yesterday but are missing from today's run",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 26 },
      "datasource": {
        "type": "postgres",
        "uid": "postgresql"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "red" },
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "inspect": false
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "City" },
            "properties": [
              { "id": "custom.width", "value": 200 }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": { "show": true, "reducer": ["count"], "countRows": true, "fields": "" },
        "frameIndex": 0
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "postgresql"
          },
          "rawSql": "WITH today_cities AS (\n  SELECT DISTINCT scr.city\n  FROM scrape_city_results scr\n  JOIN scrape_runs sr ON sr.id = scr.scrape_run_id\n  WHERE sr.started_at::date = CURRENT_DATE\n    AND scr.status = 'success'\n),\nyesterday_cities AS (\n  SELECT scr.city, scr.pharmacies_found\n  FROM scrape_city_results scr\n  JOIN scrape_runs sr ON sr.id = scr.scrape_run_id\n  WHERE sr.started_at::date = CURRENT_DATE - 1\n    AND scr.status = 'success'\n)\nSELECT y.city AS \"City\",\n       y.pharmacies_found AS \"Yesterday's Count\"\nFROM yesterday_cities y\nLEFT JOIN today_cities t ON t.city = y.city\nWHERE t.city IS NULL\nORDER BY y.pharmacies_found DESC",
          "format": "table",
          "rawQuery": true,
          "refId": "A"
        }
      ],
      "styles": [
        {
          "alias": "",
          "colorMode": "row",
          "colors": ["rgba(245, 54, 54, 0.9)", "rgba(245, 54, 54, 0.9)", "rgba(245, 54, 54, 0.9)"],
          "pattern": "/.*/",
          "type": "string"
        }
      ]
    },
