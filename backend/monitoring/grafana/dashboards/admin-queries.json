          "rawSql": "SELECT id, name, address, city, lat, lng,\n  'https://www.google.com/maps?q=' || lat || ',' || lng AS \"Google Maps\"\nFROM pharmacies\nWHERE lat IS NOT NULL\n  AND (lat < 34.5 OR lat > 42.0 OR lng < 19.0 OR lng > 30.0)\nORDER BY name\nLIMIT 100",
          "format": "table",
          "rawQuery": true,
          "refId": "A"
        }
