        "footer": { "show": true, "reducer": ["count"], "countRows": true }
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "postgresql" },
          "rawSql": "SELECT p1.id, p1.name, p1.address, p1.phone, p1.city, p1.region\nFROM pharmacies p1\nJOIN (\n  SELECT name, phone\n  FROM pharmacies\n  WHERE phone IS NOT NULL AND phone != ''\n  GROUP BY name, phone\n  HAVING COUNT(*) > 1\n) dup ON p1.name = dup.name AND p1.phone = dup.phone\nORDER BY p1.name, p1.phone\nLIMIT 200",
          "format": "table",
          "rawQuery": true,
          "refId": "A"
        }
      ]
