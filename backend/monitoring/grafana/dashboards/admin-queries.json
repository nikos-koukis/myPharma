        "footer": { "show": true, "reducer": ["count"], "countRows": true }
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "postgresql" },
          "rawSql": "SELECT p.id, p.name, p.address, p.phone, p.city, p.region, p.lat, p.lng,\n  CASE WHEN p.lat IS NOT NULL THEN 'https://www.google.com/maps?q=' || p.lat || ',' || p.lng END AS \"Google Maps\",\n  pd.duty_date, pd.duties,\n  p.created_at, p.updated_at\nFROM pharmacies p\nLEFT JOIN pharmacy_duties pd ON pd.pharmacy_id = p.id AND pd.duty_date >= CURRENT_DATE\nWHERE p.phone LIKE '%${phone:raw}%'\nORDER BY p.name, pd.duty_date\nLIMIT 100",
          "format": "table",
          "rawQuery": true,
          "refId": "A"
        }
      ]
    },
