generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [postgis]
}

model Pharmacy {
  id        String   @id @default(uuid())
  name      String
  address   String
  phone     String?
  city      String
  region    String
  lat       Float?
  lng       Float?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  duties PharmacyDuty[]

  @@unique([name, address, city])
  @@index([city])
  @@index([region])
  @@map("pharmacies")
}

model PharmacyDuty {
  id         String   @id @default(uuid())
  pharmacyId String   @map("pharmacy_id")
  dutyDate   DateTime @map("duty_date") @db.Date
  duties     Json     // Array of { start: string, end: string, type: "regular" | "extended" | "on_duty" }
  scrapedAt  DateTime @default(now()) @map("scraped_at")

  pharmacy Pharmacy @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)

  @@unique([pharmacyId, dutyDate])
  @@index([dutyDate])
  @@map("pharmacy_duties")
}

model ScrapeRun {
  id              String             @id @default(uuid())
  startedAt       DateTime           @default(now()) @map("started_at")
  finishedAt      DateTime?          @map("finished_at")
  status          String             @default("running") // "running" | "completed" | "failed"
  totalCities     Int                @default(0) @map("total_cities")
  successCities   Int                @default(0) @map("success_cities")
  failedCities    Int                @default(0) @map("failed_cities")
  totalPharmacies Int                @default(0) @map("total_pharmacies")
  totalDuties     Int                @default(0) @map("total_duties")
  durationMs      Int?               @map("duration_ms")
  errorMessage    String?            @map("error_message")
  cityResults     ScrapeCityResult[]

  @@index([startedAt])
  @@index([status])
  @@map("scrape_runs")
}

model ScrapeCityResult {
  id              String   @id @default(uuid())
  scrapeRunId     String   @map("scrape_run_id")
  city            String
  prefecture      String
  status          String   // "success" | "failed" | "no_data"
  url             String?  // The URL that was scraped
  pharmaciesFound Int      @default(0) @map("pharmacies_found")
  dutiesFound     Int      @default(0) @map("duties_found")
  durationMs      Int      @default(0) @map("duration_ms")
  httpStatus      Int?     @map("http_status")
  usedProxy       Boolean  @default(false) @map("used_proxy")
  errorMessage    String?  @map("error_message")
  scrapedAt       DateTime @default(now()) @map("scraped_at")

  scrapeRun ScrapeRun @relation(fields: [scrapeRunId], references: [id], onDelete: Cascade)

  @@index([scrapeRunId])
  @@index([city])
  @@index([scrapedAt])
  @@map("scrape_city_results")
}

model Feedback {
  id        String   @id @default(uuid())
  type      String   // "bug" | "feature" | "general" | "pharmacy_error"
  message   String
  email     String?  // Optional contact email
  appVersion String? @map("app_version")
  platform  String?  // "ios" | "android"
  deviceInfo String? @map("device_info")
  pharmacyId String? @map("pharmacy_id") // If reporting a pharmacy issue
  createdAt DateTime @default(now()) @map("created_at")

  @@index([type])
  @@index([createdAt])
  @@map("feedback")
}

model GeoValidation {
  id           String   @id @default(uuid())
  pharmacyId   String   @map("pharmacy_id")
  pharmacyName String   @map("pharmacy_name")
  address      String
  city         String
  region       String

  // Current coordinates in DB
  currentLat   Float?   @map("current_lat")
  currentLng   Float?   @map("current_lng")

  // Expected coordinates from geocoder
  expectedLat  Float?   @map("expected_lat")
  expectedLng  Float?   @map("expected_lng")

  // Validation results
  distanceKm   Float?   @map("distance_km")  // Distance between current and expected
  isValid      Boolean  @map("is_valid")     // true if distance < threshold
  issue        String?                        // Description of the issue

  validatedAt  DateTime @default(now()) @map("validated_at")

  @@index([isValid])
  @@index([distanceKm])
  @@index([region])
  @@index([validatedAt])
  @@map("geo_validations")
}

// Track failed URLs for retry (429, 503, 404 errors)
model FailedUrl {
  id           String   @id @default(uuid())
  url          String
  city         String
  prefecture   String
  httpStatus   Int      @map("http_status")  // 429, 503, 404, etc.
  errorMessage String?  @map("error_message")
  retryCount   Int      @default(0) @map("retry_count")
  maxRetries   Int      @default(5) @map("max_retries")
  lastAttempt  DateTime @default(now()) @map("last_attempt")
  nextRetry    DateTime @default(now()) @map("next_retry")
  resolved     Boolean  @default(false)  // true when successfully scraped
  resolvedAt   DateTime? @map("resolved_at")
  createdAt    DateTime @default(now()) @map("created_at")

  @@unique([url, city])  // One entry per URL per city
  @@index([httpStatus])
  @@index([resolved])
  @@index([nextRetry])
  @@index([retryCount])
  @@map("failed_urls")
}
